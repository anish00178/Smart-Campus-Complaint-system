PORT=5000

# MongoDB Atlas Connection String
# Get this from: Atlas Dashboard → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority&appName=<appName>

# JWT secret — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this

# Admin registration secret key
ADMIN_SECRET=admin@campus2026
